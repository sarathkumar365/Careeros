{
  "name": "bff",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun run --bun node_modules/.bin/nest build",
    "format": "bun run --bun node_modules/.bin/prettier \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run --bun node_modules/.bin/nest start",
    "start:dev": "bun run --bun node_modules/.bin/nest start --watch",
    "start:debug": "bun run --bun node_modules/.bin/nest start --debug --watch",
    "start:prod": "bun run --bun node dist/main",
    "lint": "bun run --bun node_modules/.bin/eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node node_modules/.bin/jest",
    "test:watch": "node node_modules/.bin/jest --watch",
    "test:cov": "node node_modules/.bin/jest --coverage",
    "test:debug": "bun run --bun node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "node node_modules/.bin/jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/websocket": "^11.2.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@prisma/client": "6.17.1",
    "@types/ws": "^8.18.1",
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "6.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "undici": "^6.22.0",
    "zod": "^4.1.12",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.37.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.6",
    "@types/amqplib": "^0.10.7",
    "@types/bun": "^1.3.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.18.10",
    "@types/supertest": "^6.0.3",
    "bun-types": "^1.3.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "ws": "^8.18.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
